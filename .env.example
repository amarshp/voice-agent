# Copy to .env and fill. Dev needs nothing (defaults to local JSON store).

# Store backend: "json" (dev, default) or "sheets" (prod)
STORE=json
BOOKINGS_PATH=data/bookings.json

# --- prod: Google Sheets store ---
# SHEET_ID=your_spreadsheet_id
# GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# --- provider keys (used by the orchestrator, not this service) ---
# SARVAM_API_KEY=
# DEEPGRAM_API_KEY=
# GEMINI_API_KEY=
